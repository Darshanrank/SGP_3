  // This is your Prisma schema file,
  // learn more about it in the docs: https://pris.ly/d/prisma-schema

  // Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
  // Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
  generator client {
    provider = "prisma-client-js"
    // output   = "../src/generated"
  }

  datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
  }


  model Users {
    userId        Int            @id @default(autoincrement())
    email         String         @unique
    passwordHash  String
    username      String         @unique
    isVerified    Boolean        @default(false)
    salt          String
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    // Profile
    profile       UserProfile?
    learningGoals LearningGoal[]
    profilePrivacy ProfilePrivacy?
    profileViewsReceived ProfileView[] @relation("ProfileViewsReceived")
    profileViewsGiven    ProfileView[] @relation("ProfileViewsGiven")

    // Skills
    userSkills    UserSkill[]

    // Swaps
    sentRequests      SwapRequest[]  @relation("SentRequests")
    receivedRequests  SwapRequest[]  @relation("ReceivedRequests")

    // Chat
    messages          ChatMessage[]

    // Classroom productivity tools
    pinnedResourcesCreated PinnedResource[] @relation("PinnedResourceCreator")
    codeSnippetsCreated    CodeSnippet[]    @relation("CodeSnippetCreator")
    classroomFilesUploaded ClassroomFile[]  @relation("ClassroomFileUploader")

    // Gamification
    rewards           UserReward?
    badges            UserBadge[]

    // Notifications & Calendar
    notifications     Notification[]
    notificationPreference NotificationPreference?
    pushSubscriptions PushSubscription[]
    reminderLogs      CalendarReminderLog[]
    calendarEvents    CalendarEvent[]
    availability      UserAvailability[]
    savedFilters      SavedFilter[]

    // Reviews
    reviewsGiven      SwapReview[]   @relation("ReviewsGiven")
    reviewsReceived   SwapReview[]   @relation("ReviewsReceived")

    // Moderation
    reportsFiled      Report[]       @relation("Reporter")
    reportsReceived   Report[]       @relation("ReportedUser")
    penalties         AdminPenalty[]
    blockedUsers      BlockedUser[]  @relation("Blocker")
    blockedByUsers    BlockedUser[]  @relation("BlockedUser")
    helpfulReviewVotes ReviewHelpfulVote[] @relation("HelpfulVotesByUser")

    // Sessions
    refreshTokens    RefreshToken[]
  }

  model UserProfile {
    id               Int      @id @default(autoincrement())
    userId           Int      @unique
    user             Users    @relation(fields: [userId], references: [userId])
    fullName         String?
    bio              String?  @db.Text
    avatarUrl        String?
    learningLanguage String?
    timezone         String?
    upcomingSessions String?  @db.Text
    emailRemindersEnabled Boolean @default(false)
    profileCompleted Boolean  @default(false)
    
    // Social Links
    githubLink       String?
    linkedinLink     String?
    portfolioLink    String?
    youtubeLink      String?
    teachingStyle    String?  @db.Text
    teachingStyles   Json?

    createdAt        DateTime @default(now())
  }

  model LearningGoal {
    id        Int      @id @default(autoincrement())
    userId    Int
    user      Users    @relation(fields: [userId], references: [userId])
    goalText  String
    createdAt DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
  }

  model ProfilePrivacy {
    id               Int      @id @default(autoincrement())
    userId           Int      @unique
    user             Users    @relation(fields: [userId], references: [userId])
    showAvailability Boolean  @default(true)
    showPortfolio    Boolean  @default(true)
    showSocialLinks  Boolean  @default(true)
    updatedAt        DateTime @updatedAt
  }

  model ProfileView {
    id        Int      @id @default(autoincrement())
    userId    Int
    user      Users    @relation("ProfileViewsReceived", fields: [userId], references: [userId])
    viewerId  Int
    viewer    Users    @relation("ProfileViewsGiven", fields: [viewerId], references: [userId])
    viewedAt  DateTime @default(now())

    @@index([userId])
    @@index([viewerId])
    @@index([viewedAt])
    @@unique([userId, viewerId, viewedAt])
  }

  model UserAvailability {
    id        Int      @id @default(autoincrement())
    userId    Int
    user      Users    @relation(fields: [userId], references: [userId])
    dayOfWeek String   // MONDAY, TUESDAY, etc.
    startTime String   // "09:00"
    endTime   String   // "17:00"
    timezone  String   // "UTC", "Asia/Kolkata"
    createdAt DateTime @default(now())

    @@index([userId])
  }

model SavedFilter {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      Users    @relation(fields: [userId], references: [userId])
  name      String
  filters   Json
  createdAt DateTime @default(now())

  @@index([userId])
}


  model Skill {
    id        Int         @id @default(autoincrement())
    name      String      @unique
    category  String
    createdAt DateTime    @default(now())
    userSkills UserSkill[]
  }

  enum SkillType {
    TEACH
    LEARN
  }

  enum SkillLevel {
    LOW
    MEDIUM
    HIGH
  }

  model UserSkill {
    id        Int       @id @default(autoincrement())
    userId    Int
    user      Users     @relation(fields: [userId], references: [userId])
    skillId   Int
    skill     Skill     @relation(fields: [skillId], references: [id])
    type      SkillType
    level     SkillLevel
    proofUrl  String?
    createdAt DateTime  @default(now())

    // Relations
    preview       SkillPreview?
    swapsToTeach  SwapRequest[] @relation("TeachSkill")
    swapsToLearn  SwapRequest[] @relation("LearnSkill")

    @@unique([userId, skillId, type])
    @@index([userId])
    @@index([skillId])
  }

  model SkillPreview {
    id              Int       @id @default(autoincrement())
    userSkillId     Int       @unique
    userSkill       UserSkill @relation(fields: [userSkillId], references: [id])
    videoUrl        String?
    description     String?   @db.Text
    syllabusOutline String?   @db.Text
    createdAt       DateTime  @default(now())
  }

  enum SwapStatus {
    PENDING
    ACCEPTED
    REJECTED
    CANCELLED
  }

  model SwapRequest {
    id            Int        @id @default(autoincrement())
    fromUserId    Int
    fromUser      Users      @relation("SentRequests", fields: [fromUserId], references: [userId])
    toUserId      Int
    toUser        Users      @relation("ReceivedRequests", fields: [toUserId], references: [userId])
    teachSkillId  Int?
    teachSkill    UserSkill?  @relation("TeachSkill", fields: [teachSkillId], references: [id])
    learnSkillId  Int
    learnSkill    UserSkill  @relation("LearnSkill", fields: [learnSkillId], references: [id])
    message       String?    @db.Text
    status        SwapStatus @default(PENDING)
    cancelReason  String?
    createdAt     DateTime   @default(now())
    updatedAt     DateTime   @updatedAt

    swapClass     SwapClass?

    @@index([fromUserId])
    @@index([toUserId])
    @@index([status])
  }

  enum ClassStatus {
    ONGOING
    COMPLETED
    CANCELLED
  }

  model SwapClass {
    id             Int             @id @default(autoincrement())
    swapRequestId  Int             @unique
    swapRequest    SwapRequest     @relation(fields: [swapRequestId], references: [id])
    classroomCode  String?
    meetLink       String?
    status         ClassStatus     @default(ONGOING)
    startedAt      DateTime?
    endedAt        DateTime?
    
    todos          ClassTodo[]
    pinnedResources PinnedResource[]
    codeSnippets   CodeSnippet[]
    classroomFiles ClassroomFile[]
    sharedNote     SharedNote?
    chatRoom       ChatRoom?
    completion     SwapCompletion?
    reviews        SwapReview[]
    calendarEvents CalendarEvent[]
  }

  model ClassTodo {
    id           Int       @id @default(autoincrement())
    swapClassId  Int
    swapClass    SwapClass @relation(fields: [swapClassId], references: [id])
    title        String
    description  String?
    dueDate      DateTime?
    isCompleted  Boolean   @default(false)
  }

  model PinnedResource {
    id          Int       @id @default(autoincrement())
    swapClassId Int
    swapClass   SwapClass @relation(fields: [swapClassId], references: [id])
    title       String
    url         String
    createdBy   Int
    creator     Users     @relation("PinnedResourceCreator", fields: [createdBy], references: [userId])
    createdAt   DateTime  @default(now())

    @@index([swapClassId])
    @@index([createdBy])
  }

  model CodeSnippet {
    id          Int       @id @default(autoincrement())
    swapClassId Int
    swapClass   SwapClass @relation(fields: [swapClassId], references: [id])
    title       String
    language    String
    code        String    @db.Text
    createdBy   Int
    creator     Users     @relation("CodeSnippetCreator", fields: [createdBy], references: [userId])
    createdAt   DateTime  @default(now())

    @@index([swapClassId])
    @@index([createdBy])
  }

  model ClassroomFile {
    id          Int       @id @default(autoincrement())
    swapClassId Int
    swapClass   SwapClass @relation(fields: [swapClassId], references: [id])
    fileName    String
    fileUrl     String
    uploadedBy  Int
    uploader    Users     @relation("ClassroomFileUploader", fields: [uploadedBy], references: [userId])
    createdAt   DateTime  @default(now())

    @@index([swapClassId])
    @@index([uploadedBy])
  }

  model SharedNote {
    id          Int       @id @default(autoincrement())
    swapClassId Int       @unique
    swapClass   SwapClass @relation(fields: [swapClassId], references: [id])
    content     String    @db.LongText
    updatedAt   DateTime  @updatedAt
  }

  model ChatRoom {
    id           Int           @id @default(autoincrement())
    swapClassId  Int           @unique
    swapClass    SwapClass     @relation(fields: [swapClassId], references: [id])
    createdAt    DateTime      @default(now())
    messages     ChatMessage[]
  }

  enum ChatMessageType {
    TEXT
    IMAGE
    FILE
  }

  model ChatMessage {
    id              Int             @id @default(autoincrement())
    chatRoomId      Int
    chatRoom        ChatRoom        @relation(fields: [chatRoomId], references: [id])
    senderId        Int
    sender          Users           @relation(fields: [senderId], references: [userId])
    message         String          @db.Text
    messageType     ChatMessageType @default(TEXT)
    attachmentUrl   String?
    attachmentName  String?
    attachmentMime  String?
    attachmentSize  Int?
    deliveredAt     DateTime?
    isRead          Boolean         @default(false)
    readAt          DateTime?
    createdAt       DateTime        @default(now())

    @@index([chatRoomId])
    @@index([senderId])
    @@index([createdAt])
    @@index([isRead])
  }

  model SwapCompletion {
    id               Int       @id @default(autoincrement())
    swapClassId      Int       @unique
    swapClass        SwapClass @relation(fields: [swapClassId], references: [id])
    completedByUser1 Boolean   @default(false)
    completedByUser2 Boolean   @default(false)
    completedAt      DateTime?
  }

  model SwapReview {
    id              Int       @id @default(autoincrement())
    swapClassId     Int
    swapClass       SwapClass @relation(fields: [swapClassId], references: [id])
    reviewerId      Int
    reviewer        Users     @relation("ReviewsGiven", fields: [reviewerId], references: [userId])
    revieweeId      Int
    reviewee        Users     @relation("ReviewsReceived", fields: [revieweeId], references: [userId])

    clarityRating       Int
    punctualityRating   Int
    communicationRating Int
    expertiseRating     Int
    overallRating       Int

    comment         String?   @db.Text
    helpfulVotes    Int       @default(0)
    verifiedSwap    Boolean   @default(true)
    createdAt       DateTime  @default(now())

    helpfulVoteRecords ReviewHelpfulVote[]

    @@unique([swapClassId, reviewerId])
    @@index([revieweeId, helpfulVotes])
    @@index([overallRating])
  }

  model ReviewHelpfulVote {
    id        Int        @id @default(autoincrement())
    reviewId  Int
    review    SwapReview @relation(fields: [reviewId], references: [id])
    userId    Int
    user      Users      @relation("HelpfulVotesByUser", fields: [userId], references: [userId])
    createdAt DateTime   @default(now())

    @@unique([reviewId, userId])
    @@index([reviewId])
    @@index([userId])
  }

  model UserReward {
    id         Int   @id @default(autoincrement())
    userId     Int   @unique
    user       Users @relation(fields: [userId], references: [userId])
    points     Int   @default(0)
    totalSwaps Int   @default(0)
  }

  model Badge {
    id        Int         @id @default(autoincrement())
    name      String      @unique
    condition String
    users     UserBadge[]
  }

  model UserBadge {
    id        Int      @id @default(autoincrement())
    userId    Int
    user      Users    @relation(fields: [userId], references: [userId])
    badgeId   Int
    badge     Badge    @relation(fields: [badgeId], references: [id])
    earnedAt  DateTime @default(now())
  }

  enum NotificationType {
    SWAP_REQUEST
    ACCEPTED
    CLASS_REMINDER
    CHAT_MESSAGE
    PARTNER_TYPING
    PARTNER_ONLINE
    SYSTEM
    ADMIN
  }

  model Notification {
    id        Int              @id @default(autoincrement())
    userId    Int
    user      Users            @relation(fields: [userId], references: [userId])
    type      NotificationType
    message   String
    isRead    Boolean          @default(false)
    link      String?
    metadata  String?          @db.Text
    createdAt DateTime         @default(now())

    @@index([userId])
    @@index([userId, isRead])
    @@index([userId, type])
    @@index([createdAt])
  }

  model NotificationPreference {
    id             Int      @id @default(autoincrement())
    userId         Int      @unique
    user           Users    @relation(fields: [userId], references: [userId])
    swapRequests   Boolean  @default(true)
    classReminders Boolean  @default(true)
    chatMessages   Boolean  @default(true)
    partnerStatus  Boolean  @default(true)
    systemAlerts   Boolean  @default(true)
    updatedAt      DateTime @updatedAt
  }

  model PushSubscription {
    id            Int      @id @default(autoincrement())
    userId        Int
    user          Users    @relation(fields: [userId], references: [userId])
    endpoint      String   @db.Text
    endpointHash  String   @unique
    p256dh        String
    auth          String
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@index([userId])
  }

  model CalendarReminderLog {
    id            Int           @id @default(autoincrement())
    userId        Int
    user          Users         @relation(fields: [userId], references: [userId])
    calendarEventId Int
    calendarEvent CalendarEvent @relation(fields: [calendarEventId], references: [id])
    minutesBefore Int
    createdAt     DateTime      @default(now())

    @@unique([userId, calendarEventId, minutesBefore])
    @@index([calendarEventId])
  }

  model CalendarEvent {
    id          Int        @id @default(autoincrement())
    userId      Int
    user        Users      @relation(fields: [userId], references: [userId])
    swapClassId Int?
    swapClass   SwapClass? @relation(fields: [swapClassId], references: [id])
    title       String
    eventDate   DateTime
    description String?
    reminderLogs CalendarReminderLog[]

    @@index([userId])
    @@index([eventDate])
  }

  enum ReportStatus {
    OPEN
    RESOLVED
    REJECTED
  }

  model Report {
    id             Int          @id @default(autoincrement())
    reporterId     Int
    reporter       Users        @relation("Reporter", fields: [reporterId], references: [userId])
    reportedUserId Int
    reportedUser   Users        @relation("ReportedUser", fields: [reportedUserId], references: [userId])
    reason         String
    status         ReportStatus @default(OPEN)
    createdAt      DateTime     @default(now())
  }

  model BlockedUser {
    id             Int      @id @default(autoincrement())
    blockerId      Int
    blocker        Users    @relation("Blocker", fields: [blockerId], references: [userId])
    blockedUserId  Int
    blockedUser    Users    @relation("BlockedUser", fields: [blockedUserId], references: [userId])
    createdAt      DateTime @default(now())

    @@unique([blockerId, blockedUserId])
    @@index([blockerId])
    @@index([blockedUserId])
  }

  enum PenaltyType {
    WARNING
    SUSPEND
    BAN
  }

  model AdminPenalty {
    id          Int         @id @default(autoincrement())
    userId      Int
    user        Users       @relation(fields: [userId], references: [userId])
    reason      String
    penaltyType PenaltyType
    createdAt   DateTime    @default(now())

    @@index([userId])
  }

  model RefreshToken {
    id                 Int      @id @default(autoincrement())
    tokenId            String   @unique
    tokenHash          String
    userId             Int
    user               Users    @relation(fields: [userId], references: [userId])
    userAgent          String?
    ip                 String?
    revoked            Boolean  @default(false)
    revokedAt          DateTime?
    replacedByTokenId  String?
    expiresAt          DateTime
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    @@index([userId])
    @@index([tokenId])
    @@index([expiresAt])
  }
